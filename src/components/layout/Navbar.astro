---
import { Icon } from 'astro-icon/components';
import Logo from '../ui/Logo.astro';
import Button from '../ui/Button.astro';
import { site } from '../../data/site.ts';
---

<header
  id="site-header"
  data-scrolled="false"
  class="fixed inset-x-0 top-0 z-50 transition-[background-color,border-color,backdrop-filter] duration-300 ease-out
    data-[scrolled=false]:bg-transparent
    data-[scrolled=true]:bg-bg-dark/85
    data-[scrolled=true]:backdrop-blur-md
    data-[scrolled=true]:border-b
    data-[scrolled=true]:border-white/8"
>
  <div class="container-page">
    <nav
      aria-label="Navegación principal"
      class="flex h-18 items-center justify-between gap-6 py-4"
    >
      <Logo variant="light" size="md" href="/" />

      <!-- Desktop nav -->
      <ul class="hidden lg:flex items-center gap-1 text-sm font-medium text-fg-dark-1">
        {site.nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="px-4 py-2 rounded-full text-fg-dark-2 hover:text-fg-dark-1 hover:bg-white/5 transition-colors duration-200"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="hidden lg:block">
        <Button href="#contacto" variant="primary" size="sm" icon="arrow-right">
          Solicitar evaluación
        </Button>
      </div>

      <!-- Mobile toggle -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="lg:hidden inline-flex items-center justify-center w-11 h-11 rounded-full text-fg-dark-1 hover:bg-white/5 transition-colors"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Abrir menú"
      >
        <Icon name="lucide:menu" class="h-6 w-6 data-[open]:hidden" data-icon-menu />
        <Icon name="lucide:x" class="h-6 w-6 hidden data-[open]:block" data-icon-close />
      </button>
    </nav>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="lg:hidden overflow-hidden max-h-0 data-[open=true]:max-h-[80vh] transition-[max-height] duration-400 ease-out bg-bg-dark border-b border-white/8"
    data-open="false"
  >
    <ul class="container-page py-6 flex flex-col gap-1">
      {site.nav.map((item) => (
        <li>
          <a
            href={item.href}
            data-mobile-link
            class="block px-4 py-3 rounded-lg text-fg-dark-1 hover:bg-white/5 text-base font-medium"
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="mt-3">
        <Button href="#contacto" variant="primary" size="md" icon="arrow-right" class="w-full" data-mobile-link>
          Solicitar evaluación
        </Button>
      </li>
    </ul>
  </div>
</header>

<!-- Spacer para compensar el header fixed -->
<div aria-hidden="true" class="h-18"></div>

<script>
  const init = () => {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!header || !toggle || !menu) return;

    // Scroll state
    const onScroll = () => {
      const scrolled = window.scrollY > 50;
      header.dataset.scrolled = String(scrolled);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    // Mobile menu
    const setOpen = (open: boolean) => {
      menu.dataset.open = String(open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
      const iconMenu = toggle.querySelector('[data-icon-menu]') as HTMLElement | null;
      const iconClose = toggle.querySelector('[data-icon-close]') as HTMLElement | null;
      if (iconMenu) iconMenu.classList.toggle('hidden', open);
      if (iconClose) iconClose.classList.toggle('hidden', !open);
      document.body.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () => {
      const isOpen = menu.dataset.open === 'true';
      setOpen(!isOpen);
    });

    // Cerrar al hacer click en un link
    menu.querySelectorAll('[data-mobile-link]').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    // Cerrar al pasar a desktop
    const mq = window.matchMedia('(min-width: 1024px)');
    mq.addEventListener('change', (e) => {
      if (e.matches) setOpen(false);
    });

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.dataset.open === 'true') setOpen(false);
    });
  };

  init();
  document.addEventListener('astro:page-load', init);
</script>
