---
import { Icon } from 'astro-icon/components';
import Logo from '../ui/Logo.astro';
import { site } from '../../data/site.ts';

const year = new Date().getFullYear();

const footerNav = [
  {
    title: 'Navegación',
    links: site.nav,
  },
  {
    title: 'Empresa',
    links: [
      { label: 'Trabaja con nosotros', href: '#carreras' },
      { label: 'Presentación corporativa (PDF)', href: site.presentationPdf, external: true },
      // TODO: Agregar redes sociales cuando el cliente las provea (LinkedIn, Instagram, etc.)
    ],
  },
];
---

<footer class="section-dark border-t border-white/8">
  <div class="container-page py-20 lg:py-24">
    <div class="grid gap-12 lg:gap-16 lg:grid-cols-[1.2fr_1fr_1fr_1.2fr]">
      <!-- Brand + descripción -->
      <div>
        <Logo variant="light" size="lg" href="/" />
        <p class="mt-5 text-fg-dark-2 text-sm leading-7 max-w-xs">
          {site.description.split('.')[0]}.
        </p>
      </div>

      <!-- Contacto -->
      <div>
        <h3 class="text-eyebrow text-fg-dark-3 mb-5">Contacto</h3>
        <ul class="space-y-3 text-sm text-fg-dark-1">
          <li>
            <a
              href={`mailto:${site.contact.email}`}
              class="inline-flex items-center gap-2.5 hover:text-accent transition-colors"
            >
              <Icon name="lucide:mail" class="h-4 w-4 text-fg-dark-3" aria-hidden="true" />
              {site.contact.email}
            </a>
          </li>
          <li>
            <a
              href={site.contact.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2.5 hover:text-accent transition-colors"
            >
              <Icon name="lucide:phone" class="h-4 w-4 text-fg-dark-3" aria-hidden="true" />
              {site.contact.phone}
            </a>
          </li>
          <li class="flex items-start gap-2.5 text-fg-dark-2">
            <Icon name="lucide:map-pin" class="h-4 w-4 text-fg-dark-3 mt-0.5 flex-shrink-0" aria-hidden="true" />
            <address class="not-italic leading-6">
              {site.contact.address.street}<br />
              {site.contact.address.district}<br />
              {site.contact.address.city}, {site.contact.address.country}
            </address>
          </li>
        </ul>
      </div>

      <!-- Navegación + Empresa -->
      {footerNav.map((col) => (
        <nav aria-label={`Footer — ${col.title}`}>
          <h3 class="text-eyebrow text-fg-dark-3 mb-5">{col.title}</h3>
          <ul class="space-y-3 text-sm">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  {...('external' in link && link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  class="inline-flex items-center min-h-11 text-fg-dark-2 hover:text-accent transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    <!-- Mapa Google Maps embed (lazy) -->
    <div class="mt-16 rounded-2xl overflow-hidden border border-white/8 bg-bg-dark-elev">
      <iframe
        src="https://www.google.com/maps?q=Badajoz+100,+Las+Condes,+Santiago,+Chile&output=embed"
        title="Ubicación de Watchman Seguridad Integral en Badajoz 100, Las Condes"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="w-full h-64 lg:h-72 border-0 grayscale-[40%] hover:grayscale-0 transition-all duration-500"
        allowfullscreen
      ></iframe>
    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-white/8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-xs text-fg-dark-3">
      <p>© {year} {site.name}. Todos los derechos reservados.</p>
      <p>Hecho con cuidado en Chile.</p>
    </div>
  </div>
</footer>
