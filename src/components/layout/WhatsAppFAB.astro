---
import { Icon } from 'astro-icon/components';
import { site } from '../../data/site.ts';
---

<a
  href={site.contact.whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
  class="wa-fab fixed bottom-5 right-5 sm:bottom-6 sm:right-6 z-40 inline-flex items-center justify-center
    w-14 h-14 rounded-full bg-wa-green text-white shadow-lg shadow-black/20
    hover:scale-110 hover:shadow-xl hover:shadow-black/30 active:scale-95
    transition-transform duration-200 ease-out
    focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-wa-green"
>
  <span class="wa-pulse" aria-hidden="true"></span>
  <Icon name="lucide:message-circle" class="h-7 w-7 relative" aria-hidden="true" />
</a>

<style>
  .wa-fab {
    isolation: isolate;
  }
  .wa-pulse {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background-color: var(--wa-green);
    opacity: 0.6;
    z-index: -1;
    animation: wa-pulse 2.4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes wa-pulse {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }
    70% {
      transform: scale(1.6);
      opacity: 0;
    }
    100% {
      transform: scale(1.6);
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-pulse {
      animation: none;
    }
  }
</style>
