---
import Button from '../ui/Button.astro';
import Reveal from '../ui/Reveal.astro';
import { site } from '../../data/site.ts';

// Texto preservado del sitio original (brief). No reescribir creativamente.
const paragraphs = [
  'Watchman Seguridad Integral es una empresa global dedicada a la prestación de servicios y asesorías en las materias inherentes a la seguridad privada, cuyo nivel Gerencial y Ejecutivo está constituido por profesionales expertos en estrategia de soluciones y servicios orientados a la gestión integral de seguridad.',
  'Nuestra empresa surge de la fusión de un grupo de profesionales de la seguridad que decidieron formar una empresa de seguridad privada innovadora en el mercado con la idea de desarrollar el concepto de seguridad integral y orientada a dar soluciones prácticas acorde a los requerimientos particulares de cada cliente.',
  'El equipo multidisciplinario de Watchman Seguridad Integral concibió una estructura empresarial basada en unidades de servicio que en forma transversal gestionan las soluciones orientadas a cubrir las necesidades de protección de nuestros clientes y sus bienes, incorporando expertos en las diferentes áreas de la seguridad para ofrecer una amplia gama de productos y servicios.',
];
---

<section id="quienes" class="section-light py-24 lg:py-32 scroll-mt-20">
  <div class="container-page">
    <div class="grid gap-12 lg:gap-20 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)]">
      <!-- Sticky title column -->
      <div class="lg:sticky lg:top-28 lg:self-start">
        <Reveal>
          <span class="text-eyebrow text-accent">Quiénes somos</span>
          <h2 class="text-h2 mt-4 text-fg-light-1">
            Una empresa global de
            <span class="text-accent">seguridad privada</span>.
          </h2>
          <p class="mt-6 text-fg-light-2 text-base leading-7 max-w-md">
            Profesionales expertos en la gestión integral de seguridad, con un enfoque
            orientado a dar soluciones prácticas para cada cliente.
          </p>
        </Reveal>
      </div>

      <!-- Body paragraphs -->
      <div>
        <div class="prose-watchman space-y-6">
          {paragraphs.map((p, i) => (
            <Reveal delay={120 * (i + 1)}>
              <p class="text-body-lg text-fg-light-2">{p}</p>
            </Reveal>
          ))}
        </div>

        <Reveal delay={520}>
          <div class="mt-12 pt-10 border-t border-black/8">
            <Button
              href={site.presentationPdf}
              variant="secondary"
              size="md"
              icon="file-down"
              iconPosition="left"
              external
            >
              Descargar presentación corporativa
            </Button>
            <p class="mt-3 text-sm text-fg-light-3">PDF · Presentación 2022 ·  Se abre en una pestaña nueva.</p>
          </div>
        </Reveal>
      </div>
    </div>
  </div>
</section>
