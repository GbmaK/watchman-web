---
import { Icon } from 'astro-icon/components';
import Button from '../ui/Button.astro';
import Reveal from '../ui/Reveal.astro';
import { site } from '../../data/site.ts';

const yearsActive = new Date().getFullYear() - site.foundedYear;
---

<section
  class="hero relative section-dark overflow-hidden isolate -mt-18 pt-18 min-h-[100svh] flex items-center"
>
  <!-- Background glows -->
  <div class="hero-glow hero-glow-1" aria-hidden="true"></div>
  <div class="hero-glow hero-glow-2" aria-hidden="true"></div>
  <!-- Subtle grid overlay -->
  <div class="hero-grid" aria-hidden="true"></div>

  <div class="container-page relative z-10 py-24 lg:py-32 w-full">
    <div class="max-w-4xl">
      <Reveal>
        <span class="inline-flex items-center gap-2 text-eyebrow text-accent">
          <span class="block h-px w-8 bg-accent"></span>
          Seguridad integral · Desde {site.foundedYear}
        </span>
      </Reveal>

      <Reveal delay={120}>
        <h1 class="text-display mt-6 text-fg-dark-1">
          La seguridad de tu empresa,
          <span class="block text-accent">en manos expertas.</span>
        </h1>
      </Reveal>

      <Reveal delay={240}>
        <p class="text-body-lg text-fg-dark-2 mt-7 max-w-2xl">
          Más de {yearsActive} años entregando soluciones de seguridad privada a empresas chilenas y
          multinacionales. Asesoría experta, tecnología de punta y respuesta integral.
        </p>
      </Reveal>

      <Reveal delay={360}>
        <div class="flex flex-wrap gap-3 mt-10">
          <Button href="#contacto" variant="primary" size="lg" icon="arrow-right">
            Solicitar evaluación
          </Button>
          <Button href="#servicios" variant="secondary" size="lg" icon="arrow-down" iconPosition="left">
            Conocer servicios
          </Button>
        </div>
      </Reveal>
    </div>
  </div>

  <!-- Scroll cue -->
  <a
    href="#quienes"
    aria-label="Bajar al contenido"
    class="scroll-cue hidden lg:flex absolute bottom-8 left-1/2 -translate-x-1/2 flex-col items-center gap-2 text-fg-dark-3 hover:text-accent transition-colors"
  >
    <span class="text-[0.7rem] tracking-[0.2em] uppercase">Scroll</span>
    <Icon name="lucide:chevron-down" class="h-5 w-5" aria-hidden="true" />
  </a>
</section>

<style>
  .hero {
    background:
      radial-gradient(ellipse 60% 50% at 85% 0%, rgba(212, 160, 23, 0.10), transparent 60%),
      radial-gradient(ellipse 50% 60% at 0% 100%, rgba(212, 160, 23, 0.06), transparent 60%),
      linear-gradient(180deg, #0a0b0d 0%, #0c0d10 100%);
  }
  .hero-glow {
    position: absolute;
    border-radius: 9999px;
    filter: blur(110px);
    opacity: 0.5;
    pointer-events: none;
    z-index: 0;
  }
  .hero-glow-1 {
    top: -10%;
    right: -10%;
    width: 32rem;
    height: 32rem;
    background: radial-gradient(circle, rgba(212, 160, 23, 0.18), transparent 70%);
  }
  .hero-glow-2 {
    bottom: -20%;
    left: -10%;
    width: 28rem;
    height: 28rem;
    background: radial-gradient(circle, rgba(212, 160, 23, 0.08), transparent 70%);
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.4;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black, transparent 75%);
  }
  .scroll-cue {
    animation: scroll-bounce 2.4s ease-in-out infinite;
  }
  @keyframes scroll-bounce {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 8px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-cue { animation: none; }
  }
</style>
