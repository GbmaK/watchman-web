---
import { Icon } from 'astro-icon/components';
import Reveal from '../ui/Reveal.astro';
import { certifications } from '../../data/certifications.ts';
---

<section aria-labelledby="certs-heading" class="section-dark py-24 lg:py-32 relative overflow-hidden isolate">
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 opacity-30"
    style="background: radial-gradient(ellipse 50% 40% at 0% 50%, rgba(212, 160, 23, 0.06), transparent 70%);"
  ></div>

  <div class="container-page">
    <div class="max-w-3xl">
      <Reveal>
        <span class="text-eyebrow text-accent">Acreditaciones</span>
      </Reveal>
      <Reveal delay={120}>
        <h2 id="certs-heading" class="text-h2 mt-4">
          Respaldados por estándares
          <span class="text-accent">nacionales e internacionales.</span>
        </h2>
      </Reveal>
    </div>

    <div class="mt-16 grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-6">
      {certifications.map((cert, i) => (
        <Reveal delay={i * 60}>
          <article
            class="aspect-[3/2] rounded-xl border border-dashed border-white/15
              bg-white/[0.02] flex flex-col items-center justify-center gap-2 p-4
              transition-colors duration-300 hover:border-accent/40"
          >
            <Icon name="lucide:award" class="h-8 w-8 text-fg-dark-3" aria-hidden="true" />
            <span class="text-xs text-fg-dark-3 text-center leading-tight">{cert.name}</span>
          </article>
        </Reveal>
      ))}
    </div>

    <Reveal delay={500}>
      <p class="mt-10 text-xs text-fg-dark-3 inline-flex items-center gap-2">
        <Icon name="lucide:info" class="h-3.5 w-3.5" aria-hidden="true" />
        Sección pendiente — el cliente proveerá los logos y nombres de las certificaciones reales.
      </p>
    </Reveal>
  </div>
</section>
