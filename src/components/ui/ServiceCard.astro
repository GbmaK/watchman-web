---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  icon: string;
  index?: number;
}

const { title, description, icon, index } = Astro.props;
const formattedIndex = index !== undefined ? String(index).padStart(2, '0') : null;
---

<article
  class="service-card group relative h-full flex flex-col rounded-2xl border border-white/8
    bg-white/[0.02] p-7 lg:p-8 overflow-hidden
    transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)]
    hover:border-accent/60 hover:bg-white/[0.04] hover:-translate-y-1
    hover:shadow-[0_20px_40px_-20px_rgba(212,160,23,0.25)]"
>
  <!-- Hover glow -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-20 -right-20 w-48 h-48 rounded-full opacity-0
      group-hover:opacity-100 transition-opacity duration-500"
    style="background: radial-gradient(circle, rgba(212, 160, 23, 0.15), transparent 70%); filter: blur(40px);"
  ></div>

  <div class="relative flex items-center justify-between">
    <div
      class="inline-flex items-center justify-center w-12 h-12 rounded-full
        bg-accent/10 text-accent transition-colors duration-300
        group-hover:bg-accent group-hover:text-bg-dark"
    >
      <Icon name={`lucide:${icon}`} class="h-6 w-6" aria-hidden="true" />
    </div>
    {formattedIndex && (
      <span class="text-xs font-mono text-fg-dark-3">{formattedIndex}</span>
    )}
  </div>

  <h3 class="relative mt-6 text-xl font-semibold text-fg-dark-1 leading-snug">
    {title}
  </h3>
  <p class="relative mt-3 text-sm text-fg-dark-2 leading-7 flex-1">{description}</p>
</article>
