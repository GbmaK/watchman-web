---
import { Icon } from 'astro-icon/components';

interface Props {
  value: number;
  prefix?: string;
  suffix?: string;
  label: string;
}

const { value, prefix = '', suffix = '', label } = Astro.props;
---

<article
  class="stat-card group relative rounded-2xl border border-white/8 bg-white/[0.02] p-8 lg:p-9
    transition-all duration-300 ease-out hover:border-accent/40 hover:bg-white/[0.04] hover:-translate-y-1"
>
  <div class="flex items-baseline gap-1 text-accent">
    <span class="text-sm font-semibold leading-none translate-y-[-0.6em]">{prefix}</span>
    <span
      class="stat-number text-[clamp(3rem,7vw,5rem)] font-extrabold tracking-tight leading-none tabular-nums"
      data-stat-value={value}
      data-stat-suffix={suffix}
    >0{suffix}</span>
  </div>

  <p class="mt-4 text-sm font-medium text-fg-dark-1 leading-snug">{label}</p>

  <div class="mt-6 pt-4 border-t border-white/8 flex items-center gap-2 text-fg-dark-3 text-xs">
    <Icon name="lucide:trending-up" class="h-3.5 w-3.5 text-accent" aria-hidden="true" />
    <span>Variación interanual</span>
  </div>
</article>

<script>
  const easeOutQuart = (t: number) => 1 - Math.pow(1 - t, 4);

  const animateNumber = (el: HTMLElement) => {
    if (el.dataset.animated === 'true') return;
    el.dataset.animated = 'true';

    const target = Number(el.dataset.statValue ?? 0);
    const suffix = el.dataset.statSuffix ?? '';

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = `${target}${suffix}`;
      return;
    }

    const duration = 1500;
    const start = performance.now();

    const tick = (now: number) => {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = easeOutQuart(progress);
      const current = Math.round(target * eased);
      el.textContent = `${current}${suffix}`;
      if (progress < 1) requestAnimationFrame(tick);
    };

    requestAnimationFrame(tick);
  };

  const init = () => {
    const numbers = document.querySelectorAll<HTMLElement>('.stat-number:not([data-animated="true"])');
    if (!numbers.length) return;

    if (!('IntersectionObserver' in window)) {
      numbers.forEach(animateNumber);
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateNumber(entry.target as HTMLElement);
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.4 }
    );

    numbers.forEach((el) => io.observe(el));
  };

  init();
  document.addEventListener('astro:page-load', init);
</script>
