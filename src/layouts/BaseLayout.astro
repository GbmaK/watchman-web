---
import '../styles/global.css';
import { site } from '../data/site.ts';

// Preload del subset latino para acelerar LCP en mobile.
import interLatin from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = `${site.name} | Soluciones de Seguridad Privada`,
  description = site.description,
  // TODO: Para máxima compatibilidad social (Twitter/X especialmente),
  // exportar /public/og-image.svg como PNG 1200×630 y referenciarlo acá.
  ogImage = '/og-image.svg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).toString();
const ogImageUrl = new URL(ogImage, site.url).toString();

const logoUrl = new URL('/favicon.svg', site.url).toString();

// JSON-LD con @graph — entidades referenciadas entre sí.
// Organization es la entidad canónica para Knowledge Panel de Google;
// SecurityService precisa la categoría de negocio; WebSite habilita SearchAction.
const orgId = `${site.url}#organization`;
const siteId = `${site.url}#website`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': orgId,
      name: site.name,
      alternateName: site.shortName,
      url: site.url,
      logo: {
        '@type': 'ImageObject',
        url: logoUrl,
        width: '64',
        height: '64',
      },
      foundingDate: String(site.foundedYear),
      address: {
        '@type': 'PostalAddress',
        streetAddress: site.contact.address.street,
        addressLocality: site.contact.address.district,
        addressRegion: 'Región Metropolitana',
        addressCountry: site.contact.address.countryCode,
      },
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: site.contact.phone,
        email: site.contact.email,
        contactType: 'customer service',
        areaServed: 'CL',
        availableLanguage: ['Spanish'],
      },
      // TODO: agregar sameAs con URLs de redes sociales cuando el cliente las provea.
      // sameAs: ['https://www.linkedin.com/company/...', 'https://www.instagram.com/...'],
    },
    {
      '@type': 'SecurityService',
      '@id': `${site.url}#service`,
      name: site.name,
      provider: { '@id': orgId },
      description: site.description,
      url: site.url,
      areaServed: { '@type': 'Country', name: 'Chile' },
      serviceType: [
        'Seguridad física',
        'Seguridad electrónica',
        'Investigación de antecedentes',
        'Análisis de inteligencia',
        'Asesoría de manejo de crisis',
        'Protección de personas importantes',
        'Análisis integral de riesgo',
        'Diseño de Salas SOC',
        'Estudios de contra inteligencia',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': siteId,
      url: site.url,
      name: site.name,
      inLanguage: site.locale,
      publisher: { '@id': orgId },
    },
  ],
};
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Indexación explícita + permisos de rich preview -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload del subset latino de Inter Variable: acelera el LCP. -->
    <link rel="preload" href={interLatin} as="font" type="font/woff2" crossorigin />

    <meta name="theme-color" content="#0A0B0D" />
    <meta name="color-scheme" content="light dark" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-bg-light text-fg-light-1 font-sans antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-bg-dark focus:text-fg-dark-1 focus:px-4 focus:py-2 focus:rounded"
    >
      Saltar al contenido
    </a>

    <slot name="header" />

    <main id="main">
      <slot />
    </main>

    <slot name="footer" />
    <slot name="fab" />
  </body>
</html>
